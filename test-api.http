@baseUrl = http://localhost:3000/api

### =========================================
### PART 1: AUTHENTICATION & SETUP
### =========================================

### 1A. Register a Student
# @name registerStudent
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Alice (Student)",
  "email": "alice@test.com",
  "password": "password123",
  "role": "STUDENT"
}

###

### 1B. Login as Student
# @name loginStudent
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "alice@test.com",
  "password": "password123"
}

###

### 1C. Fetch Subjects & Chapters (Grab an ID from the response)
# @name getSubjects
GET {{baseUrl}}/subjects

###

@subjectId = {{getSubjects.response.body.data[0].id}}
@chapterId = {{getSubjects.response.body.data[0].chapters[0].id}}

### =========================================
### PART 2: THE CORE Q&A FLOW
### =========================================

### 2A. Check for Similar Doubts (Duplicate Detection)
GET {{baseUrl}}/doubts/check-similar?subjectId={{subjectId}}

###

### 2B. Post a New Doubt
# @name postDoubt
POST {{baseUrl}}/doubts
Content-Type: application/json

{
  "title": "How does Quantum Entanglement actually work?",
  "description": "I am struggling to understand the concept of entanglement in the Classical Mechanics chapter. It feels like magic. Can someone explain?",
  "subjectId": "{{subjectId}}",
  "chapterId": "{{chapterId}}"
}

###

### 2C. AI Feature: Generate Tags for the Doubt
# Watch the AI (or NLP fallback) generate semantic tags automatically!
POST {{baseUrl}}/doubts/{{postDoubt.response.body.data.id}}/generate-tags

###

### 2D. Student Saves the Doubt for Later
POST {{baseUrl}}/doubts/{{postDoubt.response.body.data.id}}/save

### =========================================
### PART 3: FACULTY INTERACTION
### =========================================

### 3A. Register a Faculty Member
# @name registerFaculty
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Dr. Smith (Faculty)",
  "email": "faculty@test.com",
  "password": "password123",
  "role": "FACULTY"
}

###

### 3B. Login as Faculty
# @name loginFaculty
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "faculty@test.com",
  "password": "password123"
}

###

### 3C. Post a Long Answer to the Doubt
# @name postAnswer
POST {{baseUrl}}/doubts/{{postDoubt.response.body.data.id}}/answers
Content-Type: application/json

{
  "content": "Quantum entanglement is a physical phenomenon that occurs when a group of particles are generated, interact, or share spatial proximity in a way such that the quantum state of each particle of the group cannot be described independently of the state of the others, including when the particles are separated by a large distance. The topic of quantum entanglement is at the heart of the disparity between classical and quantum physics."
}

###

### 3D. AI Feature: Summarize the Long Answer
POST {{baseUrl}}/answers/{{postAnswer.response.body.data.id}}/summarize

### =========================================
### PART 4: MEETINGS & SCHEDULING
### =========================================

### 4A. Faculty Creates an Availability Slot (Requires Faculty Login!)
# You CANNOT request a meeting unless a slot exists. Run this as Faculty first.
# @name createSlot
POST {{baseUrl}}/meetings/slots
Content-Type: application/json

{
  "date": "2024-12-01T00:00:00.000Z",
  "startTime": "2024-12-01T10:00:00.000Z",
  "endTime": "2024-12-01T11:00:00.000Z"
}

###

@slotId = {{createSlot.response.body.data.id}}
@facultyId = {{createSlot.response.body.data.userId}}

### 4B. Student views Faculty Directory (Requires Student Login!)
# MUST include ?subjectId as a query parameter!
GET {{baseUrl}}/faculty/directory?subjectId={{subjectId}}

###

### 4C. Student Requests a Meeting
# Body must match createMeetingSchema. The slotId must be valid and unbooked!
# @name createMeeting
POST {{baseUrl}}/meetings
Content-Type: application/json

{
  "facultyId": "{{facultyId}}",
  "subjectId": "{{subjectId}}",
  "slotId": "{{slotId}}",
  "notes": "I need help with my physics homework"
}

###

### 4D. Faculty Accepts Meeting (Requires Faculty Login!)
# The meeting ID must be passed as a query parameter (?id=...), NOT a path parameter!
PATCH {{baseUrl}}/meetings?id={{createMeeting.response.body.data.id}}
Content-Type: application/json

{
  "status": "ACCEPTED"
}
